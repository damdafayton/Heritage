  "scripts": {
    "emulator": "cd $ANDROID_HOME/emulator && ENVFILE=.env.dev emulator @Pixel_4_API_31",
    "android": "ENVFILE=.env.dev.android react-native run-android --port=8082",
    "android:build": "ENVFILE=.env.prod npx react-native build-android --mode=release --port=8082",
    "android:rel": "ENVFILE=.env.prod react-native run-android --port=8082 --mode=release",
    "ios": "yarn pod && ENVFILE=.env.dev react-native run-ios --port=8082 --simulator 'iPhone 15 Pro'",
    "ios:test": "yarn pod && ENVFILE=.env.testnet react-native run-ios --port=8082 --device 'yucel’s iPhone'",
    "ios:rel": "yarn pod && ENVFILE=.env.prod react-native run-ios --port=8082 --device 'yucel’s iPhone' --mode Release",
    "lint": "eslint .",
    "start": "react-native start --port=8082 --reset-cache",
    "test": "jest",
    "web": "webpack serve -d source-map --mode development --config \"./web/webpack.config.js\" --color --hot",
    "build:web": "webpack --mode production --config \"./web/webpack.config.js\"",
    "pod:clean": "cd ios && rm -rf Pods && rm -rf Podfile.lock && rm -rf build && pod cache clean --all && pod install && cd ..",
    "pod:reset": "cd ios && && pod deintegrate && pod cache clean --all && pod install --repo-update && cd ..",
    "pod": "cd ios && pod install && cd ..",
    "server": "cd functions && yarn build:watch",
    "fire": "firebase emulators:start",
    "fire:deploy": "firebase deploy --only functions"
  },
